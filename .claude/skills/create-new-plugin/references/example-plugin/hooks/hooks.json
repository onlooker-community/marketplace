{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PLUGIN_ROOT\"/hooks/scripts/session-start.sh",
						"timeout": 10
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PLUGIN_ROOT\"/hooks/scripts/post-tool-use.sh",
						"timeout": 5
					}
				]
			}
		]
	}
}
