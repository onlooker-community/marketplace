		"min_days_between_runs": 6,
		"auto_run_on_session_start": true
	},
	"sources": {
		"onlooker_events": "~/.claude/logs/onlooker-events.jsonl",
		"sentinel_audit": "~/.claude/sentinel/audit.jsonl",
		"oracle_audit": "~/.claude/oracle/audit.jsonl",
		"warden_audit": "~/.claude/warden/audit.jsonl",
		"tribunal_verdicts": "~/.claude/tribunal/verdicts",
		"echo_baselines": "~/.claude/echo/runs",
		"archivist_sessions": "~/.claude/archivist/sessions"
	},
	"lore": {
		"enabled": true
	},
	"output_dir": "~/.claude/counsel",
