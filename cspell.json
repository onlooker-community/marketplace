{
	"$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/packages/cspell-types/cspell.schema.json",
	"allowCompoundWords": true,
	"caseSensitive": false,
	"dictionaries": [
		"css",
		"en_US",
		"filetypes",
		"fonts",
		"html",
		"misc",
		"node",
		"npm",
		"softwareTerms",
		"typescript"
	],
	"ignorePaths": [
		".coverage",
		".tmp",
		".vscode",
		"*.snapshot",
		"*.svg",
		"CHANGELOG.md",
		"coverage",
		"dist",
		"docs",
		"node_modules",
		".worktrees",
		".git",
		".husky"
	],
	"ignoreRandomStrings": true,
	"ignoreWords": [
		"wagoid",
		"bunx",
		"toshimaru",
		"cwds",
		"onlooker",
		"onlooker-community",
		"cksum",
		"Zheng",
		"Neur",
		"Uesato",
		"pgrep",
		"huskyrc",
		"commitlintrc",
		"meaganewaller",
		"pkill",
		"mmin",
		"reinjects",
		"gdate",
		"exfil",
		"ufeff"
	],
	"words": ["myproject", "unpushed", "fallocate", "urandom", "exfiltration", "pytest", "marcusolsson", "nerdctl", "datasource", "datasources"]
}
